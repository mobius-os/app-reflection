# Generated build output and vendored deps are not hand-written source.
dist/
.build/
node_modules/
# Manifest static_assets are install-managed (re-fetched from the manifest,
# tracked in .mobius-static-assets.json), not edited source.
static/
.mobius-static-assets.json
# Install/rollback snapshots are not source.
*.bak
*.mobius-bak
*.mobius-drop-bak
# Cron scaffolding is install-managed and must not be restored by source merges.
init-cron.sh
init-cron.sh.tombstoned
.cron-pending.json
# Python bytecode, logs, env files, editor/IDE and worktree scratch.
__pycache__/
*.py[cod]
*.log
.env
.env.local
*.swp
.idea/
.vscode/
tests/.build*/
.worktrees/
# Runtime workspaces staged by Reflection are bounded operational state, not
# catalog source. The numeric-id storage tree holds user-facing reports.
inputs/
runs/
settings.json
last-run.json
reflection-brief-template.html
fork-chat.sh
fork-session.sh
resource-history.jsonl
resource-decisions.jsonl
resource-monitor-state.json
reflection-run-metrics.jsonl
# Defensive: a numeric data directory is app storage, never source.
[0-9]*/
