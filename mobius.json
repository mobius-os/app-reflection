{
  "id": "dreaming",
  "name": "Dreaming",
  "version": "2.0.7",
  "description": "While you sleep, M\u00f6bius dreams: it interviews the agents that worked during the day, sharpens its own skills and memory, hardens your apps, and leaves you a one-page morning brief with a feedback path into chat. Quiet nights are skipped \u2014 your streak resets when you take a night off.",
  "author": "mobius-os",
  "license": "MIT",
  "homepage": "https://github.com/mobius-os/app-dreaming",
  "entry": "index.jsx",
  "icon": "icon.png",
  "offline_capable": true,
  "permissions": {
    "cross_app_access": "read",
    "share_with_apps": "none",
    "chat_log_access": "summary"
  },
  "storage_seeds": {
    "settings.json": {
      "hour": 6,
      "minute": 0,
      "timezone": null,
      "cron": "0 6 * * *",
      "exclude_apps": [],
      "agent_id": "builder",
      "provider": "claude",
      "model": null
    }
  },
  "schedule": {
    "default": "0 6 * * *",
    "user_configurable": true,
    "job": "fetch.sh"
  },
  "runtime": {
    "imports": [
      "react",
      "react-dom"
    ],
    "esm_deps": []
  },
  "embeds_agent": true
}
